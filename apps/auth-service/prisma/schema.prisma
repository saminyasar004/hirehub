generator client {
  provider = "prisma-client-js"
  output = "../generated/prisma"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  candidate
  company
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(candidate)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  @@map("users")
}
